<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="MeuCaixaPDV.MainWindow"
        Title="Sistema de Caixa - Minimercado"
        Width="1100" Height="750"
        MinWidth="900" MinHeight="600"
        Background="#F5F6FA">
    
    <!-- Recursos de estilo -->
    <Window.Styles>
        <Style Selector="TextBox">
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="Padding" Value="12,10"/>
            <Setter Property="FontSize" Value="14"/>
        </Style>
        
        <Style Selector="Button">
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Padding" Value="20,12"/>
            <Setter Property="FontSize" Value="14"/>
        </Style>
        
        <Style Selector="Button:pointerover">
            <Setter Property="Opacity" Value="0.9"/>
        </Style>
    </Window.Styles>
    
    <!-- Layout Principal -->
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="2*"/> <!-- Lista de produtos -->
            <ColumnDefinition Width="1.2*"/> <!-- Painel de pagamento -->
        </Grid.ColumnDefinitions>
        
        <!-- COLUNA ESQUERDA: PRODUTOS -->
        <Border Grid.Column="0" Background="White" Margin="15" CornerRadius="12">
            <DockPanel>
                <!-- Cabeçalho da venda -->
                <Border DockPanel.Dock="Top" Background="#2C3E50" CornerRadius="12,12,0,0" Padding="20">
                    <StackPanel>
                        <TextBlock Text="🛒 VENDA ATUAL" Foreground="White" FontSize="16" FontWeight="Bold"/>
                        <TextBlock Text="Passe o código ou digite manualmente" Foreground="#BDC3C7" FontSize="12" Margin="0,5,0,0"/>
                    </StackPanel>
                </Border>
                
                <!-- Campo de código de barras -->
                <Border DockPanel.Dock="Top" Background="#F8F9FA" Padding="15">
                    <StackPanel>
                        <TextBlock Text="📦 CÓDIGO DE BARRAS" Foreground="#7F8C8D" FontSize="12" FontWeight="Bold" Margin="0,0,0,5"/>
                        <TextBox x:Name="CodigoInput" 
                                 PlaceholderText="Digite ou passe o código aqui e pressione ENTER"
                                 FontSize="16"
                                 Background="White"
                                 BorderBrush="#DEE2E6"
                                 BorderThickness="1"/>
                    </StackPanel>
                </Border>
                
                <!-- Lista de produtos -->
                <Border DockPanel.Dock="Top" Margin="15,15,15,0">
                    <ScrollViewer Height="400" VerticalScrollBarVisibility="Auto">
                        <StackPanel x:Name="ProdutosContainer" Spacing="10"/>
                    </ScrollViewer>
                </Border>
            </DockPanel>
        </Border>
        
        <!-- COLUNA DIREITA: PAGAMENTO -->
        <Border Grid.Column="1" Background="#2C3E50" Margin="15" CornerRadius="12">
            <DockPanel>
                <!-- Cabeçalho -->
                <Border DockPanel.Dock="Top" Background="#34495E" CornerRadius="12,12,0,0" Padding="20">
                    <TextBlock Text="💰 TOTAL DA COMPRA" Foreground="White" FontSize="14" FontWeight="Bold" HorizontalAlignment="Center"/>
                </Border>
                
                <!-- Valor total -->
                <Border DockPanel.Dock="Top" Background="#2C3E50" Padding="20">
                    <StackPanel>
                        <TextBlock Text="R$" Foreground="#BDC3C7" FontSize="18" HorizontalAlignment="Center"/>
                        <TextBlock x:Name="TotalText" Foreground="#F1C40F" FontSize="48" FontWeight="Bold" HorizontalAlignment="Center" Text="0,00"/>
                    </StackPanel>
                </Border>
                
                <!-- Itens da venda (resumo) -->
                <Border DockPanel.Dock="Top" Background="#34495E" Margin="15" CornerRadius="10">
                    <StackPanel Margin="15">
                        <TextBlock Text="📋 RESUMO DA VENDA" Foreground="White" FontSize="12" FontWeight="Bold" Margin="0,0,0,10"/>
                        <ScrollViewer Height="150" VerticalScrollBarVisibility="Auto">
                            <StackPanel x:Name="ResumoContainer" Spacing="8"/>
                        </ScrollViewer>
                    </StackPanel>
                </Border>
                
                <!-- Formas de pagamento -->
                <Border DockPanel.Dock="Top" Background="#34495E" Margin="15,0,15,15" CornerRadius="10">
                    <StackPanel Margin="15">
                        <TextBlock Text="💳 FORMAS DE PAGAMENTO" Foreground="White" FontSize="12" FontWeight="Bold" Margin="0,0,0,15"/>
                        
                        <Grid ColumnDefinitions="*,*" RowDefinitions="Auto,Auto" ColumnSpacing="10" RowSpacing="10">
                            <Button Grid.Column="0" Grid.Row="0" x:Name="BtnDinheiro" 
                                    Background="#27AE60" Foreground="White" FontSize="16" Padding="20,15">
                                <StackPanel Orientation="Horizontal" Spacing="10">
                                    <TextBlock Text="💰"/>
                                    <TextBlock Text="DINHEIRO"/>
                                </StackPanel>
                            </Button>
                            
                            <Button Grid.Column="1" Grid.Row="0" x:Name="BtnPix" 
                                    Background="#3498DB" Foreground="White" FontSize="16" Padding="20,15">
                                <StackPanel Orientation="Horizontal" Spacing="10">
                                    <TextBlock Text="📱"/>
                                    <TextBlock Text="PIX"/>
                                </StackPanel>
                            </Button>
                            
                            <Button Grid.Column="0" Grid.Row="1" x:Name="BtnCartaoDebito" 
                                    Background="#E67E22" Foreground="White" FontSize="16" Padding="20,15">
                                <StackPanel Orientation="Horizontal" Spacing="10">
                                    <TextBlock Text="💳"/>
                                    <TextBlock Text="DÉBITO"/>
                                </StackPanel>
                            </Button>
                            
                            <Button Grid.Column="1" Grid.Row="1" x:Name="BtnCartaoCredito" 
                                    Background="#9B59B6" Foreground="White" FontSize="16" Padding="20,15">
                                <StackPanel Orientation="Horizontal" Spacing="10">
                                    <TextBlock Text="💎"/>
                                    <TextBlock Text="CRÉDITO"/>
                                </StackPanel>
                            </Button>
                        </Grid>
                        
                        <!-- Campo para valor recebido (quando dinheiro) -->
                        <StackPanel x:Name="TrocoPanel" Margin="0,15,0,0" IsVisible="False">
                            <TextBlock Text="💰 VALOR RECEBIDO" Foreground="#BDC3C7" FontSize="12" Margin="0,0,0,5"/>
                            <TextBox x:Name="ValorRecebidoInput" 
                                     PlaceholderText="Digite o valor recebido"
                                     Background="White"
                                     BorderBrush="#DEE2E6"
                                     BorderThickness="1"/>
                            <Button x:Name="BtnCalcularTroco" Content="CALCULAR TROCO" 
                                    Background="#3498DB" Foreground="White" Margin="0,10,0,0"/>
                            <TextBlock x:Name="TrocoText" Foreground="#F1C40F" FontSize="18" FontWeight="Bold" Margin="0,10,0,0"/>
                        </StackPanel>
                    </StackPanel>
                </Border>
                
                <!-- Status -->
                <Border DockPanel.Dock="Bottom" Background="#1A252F" CornerRadius="0,0,12,12" Padding="15">
                    <TextBlock x:Name="StatusText" Foreground="#BDC3C7" FontSize="12" Text="✅ Sistema pronto para uso"/>
                </Border>
            </DockPanel>
        </Border>
    </Grid>
</Window>