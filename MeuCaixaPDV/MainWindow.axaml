<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="MeuCaixaPDV.MainWindow"
        Title="MeuCaixa - Sistema de PDV"
        Width="1200" Height="750"
        MinWidth="1000" MinHeight="650"
        Background="#F0F2F5">
    
    <!-- Estilos Globais -->
    <Window.Styles>
        <!-- Botões principais -->
        <Style Selector="Button.PagamentoBtn">
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Padding" Value="20,12"/>
        </Style>
        
        <Style Selector="Button.PagamentoBtn:pointerover">
            <Setter Property="Opacity" Value="0.9"/>
        </Style>
        
        <!-- Cards -->
        <Style Selector="Border.Card">
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Background" Value="White"/>
        </Style>
        
        <!-- Inputs -->
        <Style Selector="TextBox">
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#D1D5DB"/>
            <Setter Property="Padding" Value="12,10"/>
            <Setter Property="FontSize" Value="14"/>
        </Style>
        
        <Style Selector="TextBox:focus">
            <Setter Property="BorderBrush" Value="#6366F1"/>
            <Setter Property="BorderThickness" Value="2"/>
        </Style>
    </Window.Styles>
    
    <DockPanel>
        <!-- Barra Superior -->
        <Border DockPanel.Dock="Top" Background="#1E293B" Padding="15,10">
            <DockPanel>
                <!-- Logo e Título -->
                <StackPanel DockPanel.Dock="Left" Orientation="Horizontal" Spacing="10">
                    <TextBlock Text="🛒" FontSize="24"/>
                    <StackPanel>
                        <TextBlock Text="MEU CAIXA" Foreground="White" FontSize="16" FontWeight="Bold"/>
                        <TextBlock Text="PDV Profissional" Foreground="#94A3B8" FontSize="11"/>
                    </StackPanel>
                </StackPanel>
                
                <!-- Ações rápidas -->
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" Spacing="10">
                    <Button x:Name="BtnRelatorio" 
                            Content="📊 RELATÓRIO" 
                            Background="#3B82F6" 
                            Foreground="White"
                            FontSize="12"
                            Padding="15,8"
                            CornerRadius="8"
                            Cursor="Hand"/>
                    
                    <Button x:Name="BtnAdmin" 
                            Content="⚙️ ADMIN" 
                            Background="#F59E0B" 
                            Foreground="White"
                            FontSize="12"
                            Padding="15,8"
                            CornerRadius="8"
                            Cursor="Hand"/>
                </StackPanel>
            </DockPanel>
        </Border>
        
        <Grid Margin="15" RowDefinitions="Auto,Auto,*">
            
            <!-- Campo de código de barras -->
            <Border Grid.Row="0" Background="White" CornerRadius="12" Margin="0,0,0,15" Padding="20">
                <StackPanel>
                    <TextBlock Text="📷 LEITOR DE CÓDIGO DE BARRAS" Foreground="#475569" FontSize="12" FontWeight="Bold" Margin="0,0,0,5"/>
                    <TextBox x:Name="CodigoInput" 
                             PlaceholderText="Digite ou passe o código aqui e pressione ENTER"
                             FontSize="16"
                             Background="White"
                             BorderBrush="#E2E8F0"
                             BorderThickness="1"/>
                    <TextBlock Text="✓ Pressione ENTER após digitar o código" Foreground="#94A3B8" FontSize="11" Margin="0,5,0,0"/>
                </StackPanel>
            </Border>
            
            <Grid Grid.Row="1" ColumnDefinitions="2*,1.2*" RowDefinitions="Auto,*">
                
                <!-- COLUNA ESQUERDA: PRODUTOS -->
                <Border Grid.Column="0" Background="White" CornerRadius="12" Padding="15" Margin="0,0,15,15">
                    <DockPanel>
                        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,15">
                            <TextBlock Text="🛍️" FontSize="20" Margin="0,0,10,0"/>
                            <TextBlock Text="PRODUTOS ADICIONADOS" FontWeight="Bold" FontSize="14" Foreground="#1E293B"/>
                            <Border x:Name="QuantidadeBadge" Background="#EF4444" CornerRadius="10" Padding="8,2" Margin="10,0,0,0">
                                <TextBlock x:Name="QuantidadeText" Text="0" Foreground="White" FontSize="11" FontWeight="Bold"/>
                            </Border>
                        </StackPanel>
                        
                        <ScrollViewer Height="350">
                            <StackPanel x:Name="ProdutosContainer" Spacing="10"/>
                        </ScrollViewer>
                    </DockPanel>
                </Border>
                
                <!-- COLUNA DIREITA: PAGAMENTO -->
                <Border Grid.Column="1" Background="White" CornerRadius="12" Padding="15" Margin="15,0,0,15">
                    <DockPanel>
                        <StackPanel DockPanel.Dock="Top" Spacing="15">
                            
                            <!-- Total -->
                            <Border Background="#F1F5F9" CornerRadius="12" Padding="20">
                                <StackPanel>
                                    <TextBlock Text="TOTAL DA COMPRA" Foreground="#64748B" FontSize="12" HorizontalAlignment="Center"/>
                                    <TextBlock x:Name="TotalText" 
                                               Text="0,00" 
                                               Foreground="#10B981" 
                                               FontSize="42" 
                                               FontWeight="Bold" 
                                               HorizontalAlignment="Center"/>
                                </StackPanel>
                            </Border>
                            
                            <!-- Botões de pagamento -->
                            <TextBlock Text="💳 FORMAS DE PAGAMENTO" Foreground="#475569" FontSize="12" FontWeight="Bold"/>
                            
                            <Grid ColumnDefinitions="*,*" RowDefinitions="Auto,Auto" ColumnSpacing="10" RowSpacing="10">
                                <Button x:Name="BtnDinheiro" Grid.Column="0" Grid.Row="0" 
                                        Content="💰 DINHEIRO" 
                                        Classes="PagamentoBtn"
                                        Background="#10B981" 
                                        Foreground="White"/>
                                
                                <Button x:Name="BtnPix" Grid.Column="1" Grid.Row="0" 
                                        Content="📱 PIX" 
                                        Classes="PagamentoBtn"
                                        Background="#6366F1" 
                                        Foreground="White"/>
                                
                                <Button x:Name="BtnCartaoDebito" Grid.Column="0" Grid.Row="1" 
                                        Content="💳 DÉBITO" 
                                        Classes="PagamentoBtn"
                                        Background="#F59E0B" 
                                        Foreground="White"/>
                                
                                <Button x:Name="BtnCartaoCredito" Grid.Column="1" Grid.Row="1" 
                                        Content="💎 CRÉDITO" 
                                        Classes="PagamentoBtn"
                                        Background="#8B5CF6" 
                                        Foreground="White"/>
                            </Grid>
                            
                            <!-- Troco Panel -->
                            <StackPanel x:Name="TrocoPanel" IsVisible="False" Spacing="10">
                                <Border Background="#FEF3C7" CornerRadius="8" Padding="10">
                                    <TextBlock Text="💰 VALOR RECEBIDO" Foreground="#92400E" FontSize="12" FontWeight="Bold"/>
                                </Border>
                                <TextBox x:Name="ValorRecebidoInput" 
                                         PlaceholderText="Digite o valor recebido"
                                         Background="#FFFBEB"
                                         BorderBrush="#FDE68A"/>
                                <Button x:Name="BtnCalcularTroco" 
                                        Content="💵 CALCULAR TROCO" 
                                        Background="#F59E0B" 
                                        Foreground="White"
                                        CornerRadius="8"
                                        Padding="15,10"
                                        FontWeight="Bold"/>
                                <TextBlock x:Name="TrocoText" Foreground="#10B981" FontSize="20" FontWeight="Bold" HorizontalAlignment="Center"/>
                            </StackPanel>
                        </StackPanel>
                    </DockPanel>
                </Border>
                
                <!-- Resumo da venda -->
                <Border Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2" Background="White" CornerRadius="12" Padding="15" Margin="0,15,0,0">
                    <DockPanel>
                        <TextBlock DockPanel.Dock="Top" Text="📋 RESUMO DA VENDA" FontWeight="Bold" FontSize="13" Foreground="#475569" Margin="0,0,0,10"/>
                        <ScrollViewer Height="100">
                            <StackPanel x:Name="ResumoContainer" Spacing="5"/>
                        </ScrollViewer>
                    </DockPanel>
                </Border>
            </Grid>
        </Grid>
        
        <!-- Barra de Status -->
        <Border DockPanel.Dock="Bottom" Background="#F8FAFC" Padding="15,10" BorderBrush="#E2E8F0" BorderThickness="0,1,0,0">
            <DockPanel>
                <TextBlock x:Name="StatusText" 
                           Text="✅ Sistema pronto! Passe o código do produto" 
                           Foreground="#475569" 
                           FontSize="12"/>
                
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" Spacing="15">
                    <TextBlock Text="🖨️ Cupom térmico" Foreground="#94A3B8" FontSize="11"/>
                    <TextBlock Text="💾 Auto-save" Foreground="#94A3B8" FontSize="11"/>
                </StackPanel>
            </DockPanel>
        </Border>
    </DockPanel>
</Window>