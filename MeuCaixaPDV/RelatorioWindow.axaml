<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="MeuCaixaPDV.RelatorioWindow"
        Title="Relatório de Vendas"
        Width="900" Height="650"
        Background="#F5F6FA">
    
    <Window.Styles>
        <Style Selector="Button">
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Padding" Value="15,10"/>
            <Setter Property="FontWeight" Value="Bold"/>
        </Style>
    </Window.Styles>
    
    <DockPanel>
        <!-- Cabeçalho -->
        <Border DockPanel.Dock="Top" Background="#2C3E50" CornerRadius="0,0,12,12" Padding="20">
            <TextBlock Text="📊 RELATÓRIO DE VENDAS" Foreground="White" FontSize="18" FontWeight="Bold"/>
        </Border>
        
        <!-- Filtros -->
        <Border DockPanel.Dock="Top" Background="White" Margin="20,20,20,10" CornerRadius="12" Padding="15">
            <Grid ColumnDefinitions="Auto,*,Auto,*,Auto" ColumnSpacing="15">
                <Button x:Name="BtnHoje" Content="HOJE" Background="#3498DB" Foreground="White"/>
                <Button x:Name="BtnSemana" Grid.Column="2" Content="ÚLTIMA SEMANA" Background="#27AE60" Foreground="White"/>
                <Button x:Name="BtnMes" Grid.Column="4" Content="ESTE MÊS" Background="#E67E22" Foreground="White"/>
            </Grid>
        </Border>
        
        <Grid Margin="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            
            <!-- Cards de resumo -->
            <Grid Grid.Row="0" ColumnDefinitions="*,*,*" ColumnSpacing="15" Margin="0,0,0,20">
                <Border Background="White" CornerRadius="12" Padding="15">
                    <StackPanel>
                        <TextBlock Text="TOTAL DE VENDAS" FontSize="12" Foreground="#7F8C8D"/>
                        <TextBlock x:Name="TotalVendasText" Text="0" FontSize="28" FontWeight="Bold" Foreground="#2C3E50"/>
                    </StackPanel>
                </Border>
                
                <Border Grid.Column="1" Background="White" CornerRadius="12" Padding="15">
                    <StackPanel>
                        <TextBlock Text="VALOR TOTAL (R$)" FontSize="12" Foreground="#7F8C8D"/>
                        <TextBlock x:Name="ValorTotalText" Text="R$ 0,00" FontSize="28" FontWeight="Bold" Foreground="#27AE60"/>
                    </StackPanel>
                </Border>
                
                <Border Grid.Column="2" Background="White" CornerRadius="12" Padding="15">
                    <StackPanel>
                        <TextBlock Text="TICKET MÉDIO" FontSize="12" Foreground="#7F8C8D"/>
                        <TextBlock x:Name="TicketMedioText" Text="R$ 0,00" FontSize="28" FontWeight="Bold" Foreground="#3498DB"/>
                    </StackPanel>
                </Border>
            </Grid>
            
            <!-- Vendas por forma de pagamento -->
            <Border Grid.Row="1" Background="White" CornerRadius="12" Padding="15" Margin="0,0,0,20">
                <StackPanel>
                    <TextBlock Text="💳 VENDAS POR FORMA DE PAGAMENTO" FontWeight="Bold" Margin="0,0,0,10"/>
                    <StackPanel x:Name="PagamentosContainer" Spacing="8"/>
                </StackPanel>
            </Border>
            
            <!-- Lista de vendas -->
            <Border Grid.Row="2" Background="White" CornerRadius="12" Padding="15">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top" Text="📋 LISTA DE VENDAS" FontWeight="Bold" Margin="0,0,0,15"/>
                    <ScrollViewer>
                        <ListBox x:Name="ListaVendas" Height="250"/>
                    </ScrollViewer>
                </DockPanel>
            </Border>
        </Grid>
    </DockPanel>
</Window>